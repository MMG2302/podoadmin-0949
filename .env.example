# === Obligatorias para el Worker (mín. 32 caracteres cada una) ===
# Local: `npm run setup:env` genera .env y .dev.vars; Wrangler lee .dev.vars.
JWT_SECRET=
REFRESH_TOKEN_SECRET=
CSRF_SECRET=

NODE_ENV=development

# Front (Vite)
VITE_BASE_URL=http://localhost:5173

# Producción: orígenes permitidos para CORS (coma-separados)
# ALLOWED_ORIGINS=https://app.tudominio.com

# Opcional: dominio mostrado en login (anti-phishing)
# OFFICIAL_APP_DOMAIN=https://app.tudominio.com

# Email, CAPTCHA, IP whitelist, etc. — ver ENV_VARIABLES.md

# Gateway IA (solo si usas funciones con AI en el Worker)
# AI_GATEWAY_BASE_URL=
# AI_GATEWAY_API_KEY=
