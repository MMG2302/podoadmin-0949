# Referencia local (sin secretos). El Worker NO lee este archivo.
# Secretos y variables del API: .dev.vars (local) o wrangler [vars] / secret put (prod).
# Generar todo con: npm run setup:env

# Copia opcional para scripts locales; Wrangler usa .dev.vars
NODE_ENV=development
APP_BASE_URL=http://localhost:5173

# Stripe — wrangler secret put / .dev.vars
# Modelo: 2 productos mensuales (clínica $100 / independiente $25)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# CLINIC_PODIATRIST_LIMIT=8
# STRIPE_PRICE_CLINIC_MONTHLY_STANDARD=price_...   # Clínica $100/mes (hasta 8 podólogos)
# STRIPE_PRICE_INDEPENDENT_MONTHLY=price_...       # Podólogo independiente $25/mes

# Trial: correo verificado + tarjeta (Stripe setup) + IP única
# TRIAL_REQUIRE_CARD=1
# TRIAL_MOCK_CARD=1          # solo dev local sin Stripe

# Opcional: protege rutas de desarrollo (/api/test, /api/auth/clear-ip-block) con header X-Dev-Secret
# DEV_API_SECRET=cambiar-en-local

# Producción en wrangler.toml [vars]:
# ALLOWED_ORIGINS=https://app.tudominio.com
# OFFICIAL_APP_DOMAIN=https://app.tudominio.com

# Email, CAPTCHA, IP whitelist, etc. — ver ENV_VARIABLES.md
