# Worker local (Wrangler). Copia a .dev.vars o ejecuta npm run setup:env
# Min. 32 caracteres en cada secreto.

JWT_SECRET=
REFRESH_TOKEN_SECRET=
CSRF_SECRET=

NODE_ENV=development
APP_BASE_URL=http://localhost:5173

# CAPTCHA: en local (NODE_ENV=development) está desactivado por defecto.
# Para probar Turnstile en local: CAPTCHA_FORCE_IN_DEV=1 y las keys CAPTCHA_*.
# En producción (NODE_ENV=production) el CAPTCHA es obligatorio para registro público.

# Verificación de email: desactivada en dev por defecto (email auto-verificado al registrarse).
# Para probar el flujo completo en local: EMAIL_VERIFICATION_FORCE_IN_DEV=1

# ALLOWED_ORIGINS=https://app.tudominio.com
# OFFICIAL_APP_DOMAIN=https://app.tudominio.com

# Observabilidad (opcional — Sentry)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Frontend build (opcional si no usas /api/public/config):
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Rate limiting (opcional; ver src/api/RATE_LIMITING.md)
# RATE_LIMIT_ANON_READ_PER_MIN=120
# RATE_LIMIT_TENANT_WRITE_PER_MIN=400

# Trial gratuito: IP + SMS + tarjeta (producción exige SMS+card por defecto)
# TRIAL_REQUIRE_SMS=1
# TRIAL_REQUIRE_CARD=1
# TRIAL_REVOKE_ON_IP_REPEAT=1
# IPQUERY_API_KEY=
# IPQUERY_BLOCK_DATACENTER=1
# IPQUERY_TRIAL_MAX_RISK_SCORE=75
# IP_TRIAL_ENFORCE_IN_DEV=1
# IPQUERY_ALLOW_UNKNOWN_IP=0
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# SMS_MOCK_CODE=123456
# SMS_MOCK_IN_DEV=1
# TRIAL_MOCK_CARD=1

# Cifrado tokens WhatsApp (opcional; si no se define, usa CSRF_SECRET)
# WHATSAPP_TOKEN_ENCRYPTION_KEY=genera-32-chars-aleatorios